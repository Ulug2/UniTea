{
  "expo": {
    "name": "UniTee",
    "slug": "unitea",
    "scheme": "myunitea",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2FC9C1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unitea.app",
      "associatedDomains": [
        "applinks:unitea.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.unitea.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "unitea.app",
              "pathPrefix": "/--"
            },
            {
              "scheme": "https",
              "host": "unitea.app",
              "pathPrefix": "/post"
            },
            {
              "scheme": "https",
              "host": "unitea.app",
              "pathPrefix": "/lostfoundpost"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon.png",
        "backgroundColor": "#2FC9C1"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them and set your profile picture.",
          "cameraPermission": "The app accesses your camera to let you take photos for your profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2FC9C1"
        }
      ]
    ],
    "owner": "unitea-team",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68f6b410-dcf2-4940-b4dd-ae968f2a91e9"
      }
    }
  }
}